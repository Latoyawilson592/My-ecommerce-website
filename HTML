<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>NexShop | Premium Tech & Workspace Essentials</title>
    <!-- Tailwind CSS CDN -->
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="styles.css">
</head>
<body class="bg-slate-50 text-slate-800 font-sans flex flex-col min-h-screen">

    <!-- Global Navigation -->
    <nav class="bg-white border-b border-slate-200 sticky top-0 z-40">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
            <a href="#" class="text-2xl font-extrabold text-indigo-600 tracking-tight">NexShop</a>
            
            <!-- Cart Trigger Button -->
            <button id="cart-btn" class="relative p-2.5 text-slate-600 hover:text-indigo-600 hover:bg-slate-50 rounded-full transition-all focus:outline-none">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
                </svg>
                <span id="cart-count" class="absolute top-1 right-1 bg-indigo-600 text-white text-[10px] w-5 h-5 rounded-full flex items-center justify-center font-bold hidden">0</span>
            </button>
        </div>
    </nav>

    <!-- Hero Section -->
    <header class="bg-gradient-to-r from-slate-900 to-indigo-950 text-white py-20 px-4 text-center">
        <div class="max-w-3xl mx-auto">
            <span class="bg-indigo-500/20 text-indigo-300 text-xs font-semibold px-3 py-1.5 rounded-full uppercase tracking-wider">Summer Collection 2026</span>
            <h1 class="text-4xl sm:text-5xl font-black mt-4 mb-4 tracking-tight">Elevate Your Desk Setup</h1>
            <p class="text-slate-300 text-lg mb-0 font-light">Explore handpicked, premium workspace accessories designed for performance and aesthetics.</p>
        </div>
    </header>

    <!-- Main Content Area -->
    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 flex-grow w-full">
        
        <!-- Feature controls: Search, Filter, and Sort -->
        <div class="bg-white p-6 rounded-xl border border-slate-200 shadow-sm mb-10 flex flex-col md:flex-row gap-4 items-center justify-between">
            <!-- Search -->
            <div class="relative w-full md:w-80">
                <input type="text" id="search-input" placeholder="Search products..." class="w-full pl-10 pr-4 py-2 bg-slate-50 border border-slate-300 rounded-lg text-sm focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition-all">
                <span class="absolute left-3 top-2.5 text-slate-400">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                    </svg>
                </span>
            </div>

            <!-- Category & Sort Controls -->
            <div class="flex flex-wrap gap-3 items-center w-full md:w-auto">
                <!-- Category Buttons (Dynamically Populated) -->
                <div id="category-filters" class="flex gap-1.5 overflow-x-auto pb-1 md:pb-0">
                    <!-- Javascript will inject filters here -->
                </div>

                <!-- Price Sorting Selector -->
                <select id="price-sort" class="bg-slate-50 border border-slate-300 rounded-lg text-sm px-3 py-2 text-slate-700 focus:ring-2 focus:ring-indigo-500 outline-none">
                    <option value="featured">Sort by: Featured</option>
                    <option value="low-high">Price: Low to High</option>
                    <option value="high-low">Price: High to Low</option>
                </select>
            </div>
        </div>

        <!-- Products Section -->
        <div>
            <div class="flex justify-between items-baseline mb-6">
                <h2 class="text-xl font-bold text-slate-900">Featured Gear</h2>
                <span id="product-results-count" class="text-sm text-slate-500">Showing all items</span>
            </div>
            
            <!-- Dynamic Grid -->
            <div id="product-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
                <!-- Javascript injects products here -->
            </div>
        </div>
    </main>

    <!-- Footer -->
    <footer class="bg-white border-t border-slate-200 py-8 text-center text-slate-500 text-sm">
        <p>&copy; 2026 NexShop. Designed for modern tech setups.</p>
    </footer>

    <!-- Cart Slide-out Drawer -->
    <div id="cart-drawer" class="fixed inset-0 z-50 overflow-hidden hidden" role="dialog" aria-modal="true">
        <div class="absolute inset-0 overflow-hidden">
            <!-- Background Overlay -->
            <div id="cart-overlay" class="absolute inset-0 bg-slate-900 bg-opacity-40 transition-opacity"></div>
            
            <div class="pointer-events-none fixed inset-y-0 right-0 flex max-w-full pl-10">
                <div class="pointer-events-auto w-screen max-w-md bg-white shadow-2xl flex flex-col">
                    <!-- Drawer Header -->
                    <div class="flex-1 overflow-y-auto py-6 px-4 sm:px-6">
                        <div class="flex items-start justify-between border-b border-slate-100 pb-5">
                            <h2 class="text-lg font-bold text-slate-950">Your Cart</h2>
                            <button id="close-cart" class="text-slate-400 hover:text-slate-600 p-1 rounded-lg hover:bg-slate-100 transition-colors">
                                <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                                </svg>
                            </button>
                        </div>

                        <!-- Dynamic Cart List -->
                        <div class="mt-6">
                            <div id="cart-items" class="flow-root divide-y divide-slate-100">
                                <!-- Cart items injected by JS -->
                            </div>
                        </div>
                    </div>

                    <!-- Checkout Drawer Footer -->
                    <div class="border-t border-slate-200 py-6 px-4 sm:px-6 bg-slate-50">
                        <div class="space-y-1.5 mb-4 text-sm text-slate-600">
                            <div class="flex justify-between">
                                <p>Subtotal</p>
                                <p id="cart-subtotal">$0.00</p>
                            </div>
                            <div class="flex justify-between">
                                <p>Estimated Shipping</p>
                                <p id="cart-shipping">Free</p>
                            </div>
                            <div class="flex justify-between font-bold text-base text-slate-950 pt-2 border-t border-slate-200">
                                <p>Total</p>
                                <p id="cart-total">$0.00</p>
                            </div>
                        </div>
                        <div class="mt-6">
                            <button onclick="handleCheckout()" class="w-full flex items-center justify-center rounded-lg bg-indigo-600 px-6 py-3 text-base font-medium text-white shadow-md hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2 transition-all">Secure Checkout</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Success Modal -->
    <div id="checkout-modal" class="fixed inset-0 z-50 flex items-center justify-center hidden">
        <div class="absolute inset-0 bg-slate-900 bg-opacity-50 backdrop-blur-sm"></div>
        <div class="bg-white rounded-xl p-8 max-w-sm w-full mx-4 relative z-10 text-center shadow-2xl border border-slate-100">
            <div class="mx-auto flex items-center justify-center h-12 w-12 rounded-full bg-emerald-100 text-emerald-600 mb-4">
                <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
            </div>
            <h3 class="text-lg font-bold text-slate-950 mb-1">Order Complete!</h3>
            <p class="text-sm text-slate-500 mb-6">Your demo purchase has been processed successfully. We've cleared your current cart.</p>
            <button id="close-modal-btn" class="w-full bg-slate-900 hover:bg-slate-800 text-white font-semibold py-2.5 rounded-lg transition-colors text-sm">Continue Browsing</button>
        </div>
    </div>

    <script src="app.js"></script>
</body>
</html>

const cartCount = document.getElementById('cart-count');
const cartSubtotal = document.getElementById('cart-subtotal');
const cartTotal = document.getElementById('cart-total');

// Checkout DOM Targets
const checkoutModal = document.getElementById('checkout-modal');
const closeModalBtn = document.getElementById('close-modal-btn');

// --- 1. SETUP ENGINE: Dynamic Categories Generation ---
function renderFilters() {
    const categories = ["All", ...new Set(products.map(p => p.category))];
    categoryFiltersContainer.innerHTML = categories.map(cat => `
        <button onclick="setCategory('${cat}')" class="px-4 py-1.5 rounded-full text-xs font-semibold whitespace-nowrap transition-all duration-200 ${
            activeCategory === cat 
            ? 'bg-indigo-600 text-white shadow-sm' 
            : 'bg-slate-100 text-slate-600 hover:bg-slate-200'
        }">
            ${cat}
        </button>
    `).join('');
}

function setCategory(category) {
    activeCategory = category;
    renderFilters();
    filterAndDisplayProducts();
}

// --- 2. DISPLAY & CONTROL: Filter, Search, and Sort Algorithms ---
function filterAndDisplayProducts() {
    // 1. Apply category filter
    let processedList = products.filter(product => {
        return activeCategory === "All" || product.category === activeCategory;
    });

    // 2. Apply text search query
    if (searchQuery.trim() !== "") {
        processedList = processedList.filter(product => 
            product.name.toLowerCase().includes(searchQuery) ||
            product.description.toLowerCase().includes(searchQuery) ||
            product.category.toLowerCase().includes(searchQuery)
        );
    }

    // 3. Apply sorting options
    if (currentSort === "low-high") {
        processedList.sort((a, b) => a.price - b.price);
    } else if (currentSort === "high-low") {
        processedList.sort((a, b) => b.price - a.price);
    }

    // Display counts
    productResultsCount.textContent = `Showing ${processedList.length} of ${products.length} items`;

    // Render Grid
    if (processedList.length === 0) {
        productGrid.innerHTML = `
            <div class="col-span-full py-16 text-center">
                <p class="text-slate-400 text-lg mb-2">No matching essentials found.</p>
                <p class="text-sm text-slate-400">Try modifying your text search parameters or resetting filters.</p>
            </div>
        `;
        return;
    }

    productGrid.innerHTML = processedList.map(product => `
        <div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden product-card flex flex-col justify-between">
            <div>
                <div class="h-48 overflow-hidden bg-slate-100 product-image-container relative">
                    <img src="${product.image}" alt="${product.name}" class="w-full h-full object-cover">
                    <span class="absolute top-2.5 left-2.5 bg-white/95 text-slate-900 text-[10px] font-bold px-2.5 py-1 rounded-md shadow-sm">
                        ${product.category}
                    </span>
                </div>
                <div class="p-5">
                    <div class="flex items-center gap-1 text-amber-500 mb-2">
                        <svg class="h-4 w-4 fill-current" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
                        <span class="text-xs font-bold text-slate-700 mt-0.5">${product.rating.toFixed(1)}</span>
                    </div>
                    <h3 class="text-base font-bold text-slate-900 leading-snug mb-1.5">${product.name}</h3>
                    <p class="text-xs text-slate-500 leading-relaxed mb-4 line-clamp-2">${product.description}</p>
                </div>
            </div>
            <div class="p-5 pt-0">
                <div class="flex items-center justify-between border-t border-slate-100 pt-4 mt-2">
                    <p class="text-lg font-black text-slate-950">$${product.price.toFixed(2)}</p>
                    <button onclick="addToCart(${product.id})" class="bg-indigo-600 hover:bg-indigo-700 text-white font-medium py-2 px-4 rounded-lg transition-all text-xs shadow-sm">
                        Add to Cart
                    </button>
                </div>
            </div>
        </div>
    `).join('');
}

// Attach Search and Sorting Listeners
searchInput.addEventListener('input', (e) => {
    searchQuery = e.target.value.toLowerCase();
    filterAndDisplayProducts();
});

priceSortSelect.addEventListener('change', (e) => {
    currentSort = e.target.value;
    filterAndDisplayProducts();
});


// --- 3. CART SYSTEM ENGINE ---
function addToCart(productId) {
    const product = products.find(p => p.id === productId);
    const existingInCart = cart.find(item => item.id === productId);

    if (existingInCart) {
        existingInCart.quantity += 1;
    } else {
        cart.push({ ...product, quantity: 1 });
    }
    
    saveAndUpdateCart();
    openCartDrawer();
}

function updateQuantity(productId, modifier) {
    const cartItem = cart.find(item => item.id === productId);
    if (cartItem) {
        cartItem.quantity += modifier;
        if (cartItem.quantity <= 0) {
            cart = cart.filter(item => item.id !== productId);
        }
    }
    saveAndUpdateCart();
}

function removeFromCart(productId) {
    cart = cart.filter(item => item.id !== productId);
    saveAndUpdateCart();
}

function saveAndUpdateCart() {
    localStorage.setItem('nexshop_cart', JSON.stringify(cart));
    updateCartUI();
}

function updateCartUI() {
    // Total Badge calculation
    const totalCount = cart.reduce((total, item) => total + item.quantity, 0);
    if (totalCount > 0) {
        cartCount.textContent = totalCount;
        cartCount.classList.remove('hidden');
    } else {
        cartCount.classList.add('hidden');
    }

    // Empty State Check
    if (cart.length === 0) {
        cartItemsContainer.innerHTML = `
            <div class="text-center py-12">
                <svg class="h-12 w-12 text-slate-300 mx-auto mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
                </svg>
                <p class="text-slate-500 font-medium">Your cart is currently empty.</p>
                <button onclick="closeCartDrawer()" class="mt-4 text-indigo-600 font-semibold text-sm hover:underline">Continue Shopping</button>
            </div>
        `;
        cartSubtotal.textContent = "$0.00";
        cartTotal.textContent = "$0.00";
        return;
    }

    // List Rendering
    cartItemsContainer.innerHTML = cart.map(item => `
        <div class="flex py-5 items-center">
            <div class="h-20 w-20 flex-shrink-0 overflow-hidden rounded-lg border border-slate-200">
                <img src="${item.image}" alt="${item.name}" class="h-full w-full object-cover">
            </div>
            <div class="ml-4 flex flex-1 flex-col justify-between">
                <div>
                    <div class="flex justify-between text-sm font-semibold text-slate-900 mb-1">
                        <h3>${item.name}</h3>
                        <p class="ml-4 font-bold text-slate-950">$${(item.price * item.quantity).toFixed(2)}</p>
                    </div>
                    <p class="text-xs text-slate-400">${item.category}</p>
                </div>
                <div class="flex items-center justify-between text-xs mt-3">
                    <!-- Custom Incrementor Controls -->
                    <div class="flex items-center border border-slate-200 rounded-md bg-white">
                        <button onclick="updateQuantity(${item.id}, -1)" class="px-2 py-1 text-slate-500 hover:bg-slate-50 font-bold">-</button>
                        <span class="px-3 font-semibold text-slate-800">${item.quantity}</span>
                        <button onclick="updateQuantity(${item.id}, 1)" class="px-2 py-1 text-slate-500 hover:bg-slate-50 font-bold">+</button>
                    </div>
                    <button type="button" onclick="removeFromCart(${item.id})" class="font-semibold text-rose-500 hover:text-rose-600 transition-colors">
                        Delete
                    </button>
                </div>
            </div>
        </div>
    `).join('');

    // Summary Subtotal Computations
    const calculatedSum = cart.reduce((total, item) => total + (item.price * item.quantity), 0);
    cartSubtotal.textContent = `$${calculatedSum.toFixed(2)}`;
    cartTotal.textContent = `$${calculatedSum.toFixed(2)}`;
}


// --- 4. SECURE CHECKOUT DYNAMICS ---
function handleCheckout() {
    if (cart.length === 0) {
        alert("Add some products to your cart before proceeding.");
        return;
    }
    closeCartDrawer();
    checkoutModal.classList.remove('hidden');
    
    // Clear cart upon successful transaction simulation
    cart = [];
    saveAndUpdateCart();
}


// --- 5. INTERFACE TOGGLES ---
function openCartDrawer() { cartDrawer.classList.remove('hidden'); }
function closeCartDrawer() { cartDrawer.classList.add('hidden'); }

cartBtn.addEventListener('click', openCartDrawer);
closeCart.addEventListener('click', closeCartDrawer);
cartOverlay.addEventListener('click', closeCartDrawer);
closeModalBtn.addEventListener('click', () => checkoutModal.classList.add('hidden'));

// Boot sequence: Render filters, catalog items, and retrieve state from local memory
renderFilters();
filterAndDisplayProducts();
updateCartUI();
